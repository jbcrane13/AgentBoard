# SwiftFormat configuration for AgentBoard
# Install: brew install swiftformat
# Run: swiftformat --config .swiftformat AgentBoard AgentBoardTests

# Indentation
--indent 4
--tabwidth 4
--indent-case false
--ifdef indent
--indent-strings false

# Spacing
--semicolons never
--commas always
# Braces
--allman false

# Length
--maxwidth 120
--wraparguments before-first
--wrapcollections before-first
--wrapparameters before-first

# Comments
--header strip

# Rules to disable
# wrapMultilineStatementBraces conflicts with SwiftLint opening_brace rule
--disable redundantSendable,trailingCommas,wrapMultilineStatementBraces

# Exclusions (generated files, third-party)
--exclude **/Generated,**/.build
